{
  "ConnectionStrings": {
    "AlasApp": "Server=(localdb)\\MSSQLLocalDB;Database=AlasApp;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Persistence": {
    "Provider": "SqlServer"
  },
  "Jwt": {
    "Issuer": "AlasApp.Api",
    "Audience": "AlasApp.Client",
    "SigningKey": "local-dev-signing-key-change-this-before-production-2026",
    "AccessTokenExpirationMinutes": 60,
    "RememberMeExpirationDays": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
